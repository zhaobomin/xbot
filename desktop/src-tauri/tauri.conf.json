{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "XBot",
  "version": "0.1.0",
  "identifier": "ai.xbot.desktop",
  "build": {
    "beforeDevCommand": "cd ../xbot/interfaces/webui/frontend && npm run dev",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "cd ../xbot/interfaces/webui/frontend && npm run build",
    "frontendDist": "../../xbot/interfaces/webui/frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "XBot",
        "width": 1280,
        "height": 840,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
