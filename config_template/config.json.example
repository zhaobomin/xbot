{
  "agents": {
    "type": "claude_sdk",
    "defaults": {
      "workspace": "~/.xbot/workspace",
      "model": "glm-5",
      "provider": "aliyun_coding_plan",
      "max_tokens": 8192,
      "max_tool_iterations": 40
    },
    "claude_sdk": {
      "max_turns": 40,
      "permission_mode": "bypassPermissions"
    }
  },
  "providers": {
    "aliyun_coding_plan": {
      "api_key": "YOUR_API_KEY_HERE",
      "api_base": "https://coding.dashscope.aliyuncs.com/apps/anthropic"
    }
  },
  "channels": {
    "send_progress": true,
    "send_tool_hints": true,
    "telegram": {
      "enabled": true,
      "token": "YOUR_TELEGRAM_BOT_TOKEN_HERE",
      "allow_from": ["*"],
      "reply_to_message": false,
      "group_policy": "mention",
      "proxy": null
    }
  },
  "tools": {
    "web": {
      "proxy": null,
      "disable_security_checks": true,
      "search": {
        "provider": "duckduckgo",
        "api_key": "",
        "max_results": 5
      }
    },
    "exec": {
      "timeout": 60,
      "path_append": ""
    },
    "restrict_to_workspace": false,
    "mcp_servers": {}
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18790,
    "heartbeat": {
      "enabled": true,
      "interval_s": 1800
    }
  }
}
