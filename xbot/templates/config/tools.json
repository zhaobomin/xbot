{
  "web": {
    "proxy": null,
    "search": {
      "provider": "duckduckgo",
      "max_results": 5
    }
  },
  "exec": {
    "timeout": 60
  },
  "memory": {
    "auto_memory_enabled": true,
    "extract_memories_enabled": true,
    "auto_dream_enabled": true,
    "auto_dream_min_hours": 24,
    "auto_dream_min_sessions": 5,
    "memory_recall_max_files": 5
  }
}
