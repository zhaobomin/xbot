[sources]
directories = ["/Users/zhaobomin/.xbot/workspace"]
include_globs = ["**/*.md", "**/*.docx", "**/*.pptx", "**/*.pdf", "**/*.txt"]
exclude_globs = ["**/.git/**", "**/node_modules/**", "**/.venv/**"]

[mem0]
host = "https://api.mem0.ai"
api_key_env = "MEM0_API_KEY"
user_id = "xbot-global"
app_id = "memory-ingest"
timeout_seconds = 30

[extract]
model = "kimi-k2.5"
provider = "openai_compatible"
api_base = "https://coding.dashscope.aliyuncs.com/v1"
api_key_env = "MEMORY_INGEST_API_KEY"
max_chunk_chars = 4000
min_confidence = 0.72

[dedup]
enabled = true
fingerprint_similarity = 0.9

[state]
sqlite_path = "~/.memory-ingest/state.db"

[logging]
level = "INFO"
log_path = "~/.memory-ingest/memory-ingest.log"
